# --- OpenShift Bağlantı Ayarları ---
# API URL'sini "oc whoami --show-server" ile öğrenebilirsin.
# Örnek: https://api.dev-cluster.sirket.local:6443
OPENSHIFT_API_URL=https://api.<cluster-domain>:6443

# Personal Access Token (Web Console -> sağ üst kullanıcı -> "Copy login command" -> "Display Token")
# Genelde "sha256~..." formatında olur. ServiceAccount token kullanıyorsan JWT formatında olur.
OPENSHIFT_TOKEN=REPLACE_ME

# Self-signed sertifika kullanan iç clusterlar için "false" yapabilirsin.
# Üretimde kesinlikle "true" tut ve aşağıdaki CA dosyasını kullan.
OPENSHIFT_VERIFY_SSL=true

# (Opsiyonel) Şirket içi CA bundle dosyasının tam yolu.
# Boş bırakılırsa sistem CA'leri kullanılır.
OPENSHIFT_CA_BUNDLE=

# (Opsiyonel) HTTP timeout saniyesi
OPENSHIFT_TIMEOUT=15

# (Opsiyonel) Çoğu işlemin varsayılan namespace'i
OPENSHIFT_NAMESPACE=

# (Opsiyonel) Yazma tool'ları için emniyet bandı; default 10
OPENSHIFT_MAX_REPLICAS=10

# --- LLM Client (mevcut client.py için) ---
GEMINI_API_KEY=
